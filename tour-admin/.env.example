# Configuración del SDK web de Firebase para el frontend.
# Copia este archivo como .env (no se versiona) y rellena con los valores de:
#   Firebase Console -> Configuración del proyecto -> Tus apps -> App web -> Configuración del SDK
#
# Checklist en Firebase Console antes de probar el login:
#   1. Authentication -> Sign-in method -> Google habilitado.
#   2. Authentication -> Settings -> Authorized domains incluye localhost y 127.0.0.1
#      (y los dominios de Hosting / staging cuando apliquen).
#   3. Firestore Database creada y reglas desplegadas (firestore.rules).
#   4. Storage bucket creado y reglas desplegadas (storage.rules).
#   5. Documento usuarios_sistema/{uid} creado para tu cuenta de prueba con activo=true.
#
# IMPORTANTE: nunca pongas secretos del backend (service accounts, claves Gmail) aquí.
# Las variables VITE_* viajan al bundle del navegador.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: solo necesario si activas Firebase Analytics en el cliente.
VITE_FIREBASE_MEASUREMENT_ID=

# Opcional: región de Cloud Functions si despliegas fuera de us-central1.
VITE_FIREBASE_FUNCTIONS_REGION=
